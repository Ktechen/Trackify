<Page x:Class="Trackify.Presentation.Pages.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:Trackify.Presentation.Components"
      xmlns:vm="using:Trackify.Presentation.ViewModels"
      xmlns:utu="using:Uno.Toolkit.UI"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      d:DataContext="{d:DesignInstance Type=vm:MainViewModel}"
      NavigationCacheMode="Required"
      Background="{ThemeResource BackgroundBrush}">

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition />
    </Grid.RowDefinitions>

    <!-- HEADER — background fills behind the status bar; content is padded into the safe area. -->
    <Grid Grid.Row="0"
          Padding="16,12"
          utu:SafeArea.Insets="Top,Left,Right"
          Background="{ThemeResource SurfaceBrush}"
          BorderBrush="{ThemeResource SurfaceVariantBrush}"
          BorderThickness="0,0,0,1">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>

      <!-- Back to list (narrow layout only; toggled from code-behind) -->
      <Button x:Name="BackButton" Grid.Column="0" Style="{StaticResource IconButtonStyle}" Margin="0,0,6,0"
              Visibility="Collapsed" Command="{Binding BackToListCommand}" ToolTipService.ToolTip="Zurück zur Liste">
        <FontIcon Glyph="&#xE72B;" FontSize="16" />
      </Button>

      <Border Grid.Column="1" Width="42" Height="42" CornerRadius="13" Background="{ThemeResource PrimaryContainerBrush}" Margin="0,0,14,0">
        <Grid Width="24" Height="24">
          <Path Data="M5 4h11a3 3 0 0 1 3 3v8H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2Z" Fill="{ThemeResource OnPrimaryContainerBrush}" />
          <Ellipse Width="4" Height="4" Fill="{ThemeResource OnPrimaryContainerBrush}" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="6,16,0,0" />
          <Ellipse Width="4" Height="4" Fill="{ThemeResource OnPrimaryContainerBrush}" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="14,16,0,0" />
        </Grid>
      </Border>

      <StackPanel Grid.Column="2" VerticalAlignment="Center" Spacing="1">
        <TextBlock Text="Train-Konfiguration" FontSize="16" FontWeight="Bold" />
        <TextBlock Text="Powered Up · Legoino-Schnittstelle" Style="{StaticResource MonoCaptionTextBlockStyle}" />
      </StackPanel>

      <StackPanel x:Name="HeaderStats" Grid.Column="4" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center" Margin="0,0,16,0">
        <TextBlock Text="{Binding ActiveCount}" FontFamily="{StaticResource MonoFontFamily}" FontSize="12" FontWeight="SemiBold" />
        <TextBlock Text="aktiv ·" FontFamily="{StaticResource MonoFontFamily}" FontSize="12" Foreground="{ThemeResource OnSurfaceVariantBrush}" />
        <TextBlock Text="{Binding TotalCount}" FontFamily="{StaticResource MonoFontFamily}" FontSize="12" FontWeight="SemiBold" />
        <TextBlock Text="gesamt" FontFamily="{StaticResource MonoFontFamily}" FontSize="12" Foreground="{ThemeResource OnSurfaceVariantBrush}" />
      </StackPanel>

      <!-- Visibility owned by ApplyResponsiveLayout in code-behind (depends on width AND selection). -->
      <Border x:Name="HeaderChip" Grid.Column="5" Style="{StaticResource ChipBorderStyle}" Margin="0,0,10,0" Visibility="Collapsed">
        <StackPanel Orientation="Horizontal" Spacing="5">
          <Ellipse Width="7" Height="7" VerticalAlignment="Center"
                    Fill="{Binding SelectedTrain.IsHardwareConnected, Converter={StaticResource BoolToStatusBrushConverter}}" />
          <TextBlock Text="{Binding SelectedTrain.ConnectionStatus}" FontSize="11" Foreground="{ThemeResource OnSurfaceVariantBrush}" />
        </StackPanel>
      </Border>

      <Button Grid.Column="6" Style="{StaticResource IconButtonStyle}" Command="{Binding GoToStreckenplanerCommand}" ToolTipService.ToolTip="Streckenplaner öffnen">
        <FontIcon Glyph="&#xE8A1;" FontSize="16" />
      </Button>
    </Grid>

    <!-- CONTENT: responsive master-detail (columns/visibility driven by code-behind) -->
    <Grid x:Name="ContentGrid" Grid.Row="1" utu:SafeArea.Insets="Bottom,Left,Right">
      <Grid.ColumnDefinitions>
        <ColumnDefinition x:Name="ListColumn" Width="346" />
        <ColumnDefinition x:Name="EditorColumn" Width="*" />
      </Grid.ColumnDefinitions>

      <local:TrainListPanel x:Name="ListPanel" Grid.Column="0" />
      <local:TrainEditor x:Name="EditorHost" Grid.Column="1" />
    </Grid>

    <!-- ADD-HUB POPUP (modal overlay across the whole page) -->
    <local:AddHubDialog Grid.Row="0" Grid.RowSpan="2" />
  </Grid>
</Page>
