<Page x:Class="Trackify.Presentation.MainPage"
      x:Name="RootPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:Trackify.Presentation"
      NavigationCacheMode="Required"
      Background="{ThemeResource BackgroundBrush}">

  <Page.Resources>
    <local:HexToBrushConverter x:Key="HexToBrushConverter" />
    <local:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
    <local:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    <local:BoolToStatusBrushConverter x:Key="BoolToStatusBrushConverter" />
    <local:SegmentBackgroundConverter x:Key="SegmentBackgroundConverter" />
    <local:SegmentForegroundConverter x:Key="SegmentForegroundConverter" />
    <local:BoolToThicknessConverter x:Key="BoolToThicknessConverter" />
    <local:ValidityToBrushConverter x:Key="ValidityToBrushConverter" />
    <local:InverseBoolConverter x:Key="InverseBoolConverter" />
  </Page.Resources>

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition />
    </Grid.RowDefinitions>

    <!-- HEADER -->
    <Grid Grid.Row="0"
          Padding="16,12"
          Background="{ThemeResource SurfaceBrush}"
          BorderBrush="{ThemeResource SurfaceVariantBrush}"
          BorderThickness="0,0,0,1">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>

      <!-- Back to list (narrow layout only; toggled from code-behind) -->
      <Button x:Name="BackButton" Grid.Column="0" Style="{StaticResource IconButtonStyle}" Margin="0,0,6,0"
              Visibility="Collapsed" Command="{Binding BackToListCommand}" ToolTipService.ToolTip="Zurück zur Liste">
        <FontIcon Glyph="&#xE72B;" FontSize="16" />
      </Button>

      <Border Grid.Column="1" Width="42" Height="42" CornerRadius="13" Background="{ThemeResource PrimaryContainerBrush}" Margin="0,0,14,0">
        <Grid Width="24" Height="24">
          <Path Data="M5 4h11a3 3 0 0 1 3 3v8H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2Z" Fill="{ThemeResource OnPrimaryContainerBrush}" />
          <Ellipse Width="4" Height="4" Fill="{ThemeResource OnPrimaryContainerBrush}" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="6,16,0,0" />
          <Ellipse Width="4" Height="4" Fill="{ThemeResource OnPrimaryContainerBrush}" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="14,16,0,0" />
        </Grid>
      </Border>

      <StackPanel Grid.Column="2" VerticalAlignment="Center" Spacing="1">
        <TextBlock Text="Train-Konfiguration" FontSize="16" FontWeight="Bold" />
        <TextBlock Text="Powered Up · Legoino-Schnittstelle" Style="{StaticResource MonoCaptionTextBlockStyle}" />
      </StackPanel>

      <StackPanel x:Name="HeaderStats" Grid.Column="4" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center" Margin="0,0,16,0">
        <TextBlock Text="{Binding ActiveCount}" FontFamily="{StaticResource MonoFontFamily}" FontSize="12" FontWeight="SemiBold" />
        <TextBlock Text="aktiv ·" FontFamily="{StaticResource MonoFontFamily}" FontSize="12" Foreground="{ThemeResource OnSurfaceVariantBrush}" />
        <TextBlock Text="{Binding TotalCount}" FontFamily="{StaticResource MonoFontFamily}" FontSize="12" FontWeight="SemiBold" />
        <TextBlock Text="gesamt" FontFamily="{StaticResource MonoFontFamily}" FontSize="12" Foreground="{ThemeResource OnSurfaceVariantBrush}" />
      </StackPanel>

      <!-- Visibility is owned by ApplyResponsiveLayout in code-behind (depends on width AND selection). -->
      <Border x:Name="HeaderChip" Grid.Column="5" Style="{StaticResource ChipBorderStyle}" Margin="0,0,10,0" Visibility="Collapsed">
        <StackPanel Orientation="Horizontal" Spacing="5">
          <Ellipse Width="7" Height="7" VerticalAlignment="Center"
                    Fill="{Binding SelectedTrain.IsHardwareConnected, Converter={StaticResource BoolToStatusBrushConverter}}" />
          <TextBlock Text="{Binding SelectedTrain.ConnectionStatus}" FontSize="11" Foreground="{ThemeResource OnSurfaceVariantBrush}" />
        </StackPanel>
      </Border>

      <Button Grid.Column="6" Style="{StaticResource IconButtonStyle}" Command="{Binding GoToStreckenplanerCommand}" ToolTipService.ToolTip="Streckenplaner öffnen">
        <FontIcon Glyph="&#xE8A1;" FontSize="16" />
      </Button>
    </Grid>

    <Grid x:Name="ContentGrid" Grid.Row="1">
      <Grid.ColumnDefinitions>
        <ColumnDefinition x:Name="ListColumn" Width="346" />
        <ColumnDefinition x:Name="EditorColumn" Width="*" />
      </Grid.ColumnDefinitions>

      <!-- LIST -->
      <Grid x:Name="ListPanel" Grid.Column="0" Background="{ThemeResource SurfaceBrush}" BorderBrush="{ThemeResource SurfaceVariantBrush}" BorderThickness="0,0,1,0">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Padding="16,16,16,14" Spacing="12">
          <Grid>
            <TextBox Text="{Binding Search, Mode=TwoWay}"
                     PlaceholderText="Train suchen…"
                     Padding="34,11,14,11"
                     BorderThickness="0"
                     CornerRadius="{StaticResource RadiusFull}"
                     Background="{ThemeResource SurfaceVariantBrush}"
                     FontSize="13.5" />
            <FontIcon Glyph="&#xE721;" FontSize="14" Margin="13,0,0,0" HorizontalAlignment="Left" Foreground="{ThemeResource OnSurfaceVariantBrush}" IsHitTestVisible="False" />
          </Grid>

          <!-- DISCOVER -->
          <Button HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                  Command="{Binding DiscoverCommand}" IsEnabled="{Binding IsDiscovering, Converter={StaticResource InverseBoolConverter}}">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <FontIcon Glyph="&#xE702;" FontSize="15" />
              <TextBlock Text="Hub suchen" />
            </StackPanel>
          </Button>

          <Border Background="{ThemeResource SurfaceVariantBrush}" CornerRadius="{StaticResource RadiusLarge}" Padding="12,10"
                  Visibility="{Binding DiscoverStatus, Converter={StaticResource NullToVisibilityConverter}}">
            <StackPanel Spacing="8">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto" />
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <ProgressRing Grid.Column="0" Width="16" Height="16" Margin="0,0,8,0" VerticalAlignment="Center"
                              IsActive="{Binding IsDiscovering}"
                              Visibility="{Binding IsDiscovering, Converter={StaticResource BoolToVisibilityConverter}}" />
                <TextBlock Grid.Column="1" Text="{Binding DiscoverStatus}" TextWrapping="Wrap" VerticalAlignment="Center"
                           FontSize="12" Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                <!-- While scanning: Stopp. Otherwise: clear the results. -->
                <Button Grid.Column="2" Content="Stopp" Padding="12,4" Command="{Binding StopDiscoverCommand}"
                        Visibility="{Binding IsDiscovering, Converter={StaticResource BoolToVisibilityConverter}}" />
                <Button Grid.Column="2" Style="{StaticResource IconButtonStyle}" Command="{Binding ClearDiscoverCommand}"
                        ToolTipService.ToolTip="Ergebnisse ausblenden"
                        Visibility="{Binding IsDiscovering, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}">
                  <FontIcon Glyph="&#xE711;" FontSize="12" />
                </Button>
              </Grid>
              <ItemsControl ItemsSource="{Binding DiscoveredHubs}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Button HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Margin="0,4,0,0" Padding="12,8"
                            Command="{Binding ElementName=RootPage, Path=DataContext.UseDiscoveredHubCommand}"
                            CommandParameter="{Binding}">
                      <StackPanel Spacing="2">
                        <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                        <TextBlock Text="{Binding MacAddress}" Style="{StaticResource MonoCaptionTextBlockStyle}" />
                      </StackPanel>
                    </Button>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </Border>

          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Content="Alle" Style="{StaticResource SegmentPillButtonStyle}"
                    CornerRadius="19,0,0,19"
                    Background="{Binding Filter, Converter={StaticResource SegmentBackgroundConverter}, ConverterParameter=All}"
                    Foreground="{Binding Filter, Converter={StaticResource SegmentForegroundConverter}, ConverterParameter=All}"
                    Command="{Binding SetFilterCommand}" CommandParameter="All" />
            <Button Grid.Column="1" Content="Aktiv" Style="{StaticResource SegmentPillButtonStyle}"
                    CornerRadius="0" Margin="-1,0,0,0"
                    Background="{Binding Filter, Converter={StaticResource SegmentBackgroundConverter}, ConverterParameter=Active}"
                    Foreground="{Binding Filter, Converter={StaticResource SegmentForegroundConverter}, ConverterParameter=Active}"
                    Command="{Binding SetFilterCommand}" CommandParameter="Active" />
            <Button Grid.Column="2" Content="Inaktiv" Style="{StaticResource SegmentPillButtonStyle}"
                    CornerRadius="0,19,19,0" Margin="-1,0,0,0"
                    Background="{Binding Filter, Converter={StaticResource SegmentBackgroundConverter}, ConverterParameter=Inactive}"
                    Foreground="{Binding Filter, Converter={StaticResource SegmentForegroundConverter}, ConverterParameter=Inactive}"
                    Command="{Binding SetFilterCommand}" CommandParameter="Inactive" />
          </Grid>
        </StackPanel>

        <ListView Grid.Row="1"
                  ItemsSource="{Binding FilteredTrains}"
                  SelectedItem="{Binding SelectedTrain, Mode=TwoWay}"
                  SelectionMode="Single"
                  Padding="10,2,10,10">
          <ListView.ItemContainerStyle>
            <Style TargetType="ListViewItem">
              <Setter Property="Padding" Value="0" />
              <Setter Property="Margin" Value="0,0,0,4" />
              <Setter Property="CornerRadius" Value="{StaticResource RadiusLarge}" />
              <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            </Style>
          </ListView.ItemContainerStyle>
          <ListView.ItemTemplate>
            <DataTemplate>
              <Grid Padding="10" ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto" />
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Width="42" Height="42" CornerRadius="12"
                        Background="{Binding ColorHex, Converter={StaticResource HexToBrushConverter}}" Opacity=".88">
                  <Grid Width="23" Height="23">
                    <Path Data="M5 4h11a3 3 0 0 1 3 3v8H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2Z" Fill="White" />
                    <Ellipse Width="4" Height="4" Fill="#1D1B20" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="6,15,0,0" />
                    <Ellipse Width="4" Height="4" Fill="#1D1B20" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="13,15,0,0" />
                  </Grid>
                </Border>

                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                  <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                  <TextBlock Text="{Binding PortSummary}" Style="{StaticResource MonoCaptionTextBlockStyle}" TextTrimming="CharacterEllipsis" />
                </StackPanel>

                <Ellipse Grid.Column="2" Width="9" Height="9" VerticalAlignment="Center"
                          Fill="{Binding IsActive, Converter={StaticResource BoolToStatusBrushConverter}}" />
              </Grid>
            </DataTemplate>
          </ListView.ItemTemplate>
        </ListView>

        <Button Grid.Row="2" Margin="16,14,16,14" Style="{StaticResource FabButtonStyle}" Command="{Binding AddTrainCommand}">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <FontIcon Glyph="&#xE710;" FontSize="16" />
            <TextBlock Text="Neuer Train" />
          </StackPanel>
        </Button>
      </Grid>

      <!-- EDITOR -->
      <Grid x:Name="EditorHost" Grid.Column="1">
        <ScrollViewer Visibility="{Binding SelectedTrain, Converter={StaticResource NullToVisibilityConverter}}">
          <StackPanel MaxWidth="560" HorizontalAlignment="Stretch" Margin="16,20,16,48" Spacing="16">

            <!-- HEADER ROW -->
            <Grid ColumnSpacing="16">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>

              <Border Width="58" Height="58" CornerRadius="16"
                      Background="{Binding SelectedTrain.ColorHex, Converter={StaticResource HexToBrushConverter}}" Opacity=".88">
                <Grid Width="34" Height="34">
                  <Path Data="M5 4h11a3 3 0 0 1 3 3v8H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2Z" Fill="White" />
                  <Ellipse Width="6" Height="6" Fill="#1D1B20" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="9,22,0,0" />
                  <Ellipse Width="6" Height="6" Fill="#1D1B20" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="19,22,0,0" />
                </Grid>
              </Border>

              <StackPanel Grid.Column="1" Margin="0,2,0,0">
                <TextBox Text="{Binding SelectedTrain.Name, Mode=TwoWay}" FontSize="25" FontWeight="Bold"
                         Background="Transparent" BorderThickness="0" Padding="0" />
                <StackPanel Orientation="Horizontal" Spacing="4" Margin="0,3,0,0">
                  <TextBlock Text="ID" Style="{StaticResource MonoCaptionTextBlockStyle}" />
                  <TextBlock Text="{Binding SelectedTrain.Id}" Style="{StaticResource MonoCaptionTextBlockStyle}" />
                  <TextBlock Text="·" Style="{StaticResource MonoCaptionTextBlockStyle}" />
                  <TextBlock Text="{Binding SelectedTrain.BleAddress}" Style="{StaticResource MonoCaptionTextBlockStyle}" />
                </StackPanel>
              </StackPanel>

              <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                <TextBlock Text="{Binding SelectedTrain.StatusLabel}" FontSize="12.5" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,2,0" />
                <ToggleSwitch IsOn="{Binding SelectedTrain.IsActive, Mode=TwoWay}" OnContent="" OffContent="" />
                <Button Style="{StaticResource IconButtonStyle}" Command="{Binding DuplicateTrainCommand}" ToolTipService.ToolTip="Duplizieren">
                  <FontIcon Glyph="&#xE8C8;" FontSize="15" />
                </Button>
                <Button Style="{StaticResource IconButtonStyle}" Command="{Binding DeleteTrainCommand}" ToolTipService.ToolTip="Löschen" Foreground="{ThemeResource ErrorBrush}">
                  <FontIcon Glyph="&#xE74D;" FontSize="15" />
                </Button>
              </StackPanel>
            </Grid>

            <!-- VERBINDUNG -->
            <Border Style="{StaticResource SectionCardStyle}">
              <StackPanel>
                <TextBlock Text="Verbindung" Style="{StaticResource SectionTitleTextBlockStyle}" Margin="0,0,0,16" />
                <StackPanel Spacing="14">
                  <StackPanel Spacing="7">
                    <TextBlock Text="Hub-Typ" Style="{StaticResource LabelTextBlockStyle}" />
                    <ComboBox ItemsSource="{Binding HubOptions}" DisplayMemberPath="Label" SelectedValuePath="Value"
                              SelectedValue="{Binding SelectedTrain.Hub, Mode=TwoWay}" HorizontalAlignment="Stretch" />
                    <TextBlock Text="{Binding SelectedTrain.HubToken}" Style="{StaticResource MonoCaptionTextBlockStyle}" />
                  </StackPanel>
                  <StackPanel Spacing="7">
                    <TextBlock Text="BLE-Adresse" Style="{StaticResource LabelTextBlockStyle}" />
                    <TextBox Text="{Binding SelectedTrain.BleAddress, Mode=TwoWay}" PlaceholderText="90:84:2B:xx:xx:xx"
                             FontFamily="{StaticResource MonoFontFamily}" FontSize="12.5" />
                    <TextBlock Text="MAC · zum Verbinden" Style="{StaticResource MonoCaptionTextBlockStyle}" />
                  </StackPanel>
                </StackPanel>

                <StackPanel Margin="0,16,0,0" Spacing="10">
                  <StackPanel Orientation="Horizontal" Spacing="10">
                    <Button Content="Verbinden" Command="{Binding ConnectCommand}" Style="{StaticResource FabButtonStyle}" Padding="16,0" />
                    <Button Content="Trennen" Command="{Binding DisconnectCommand}" Padding="16,0" />
                  </StackPanel>
                  <Grid ColumnSpacing="6">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="Auto" />
                      <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Ellipse Grid.Column="0" Width="8" Height="8" VerticalAlignment="Top" Margin="0,4,0,0"
                             Fill="{Binding SelectedTrain.IsHardwareConnected, Converter={StaticResource BoolToStatusBrushConverter}}" />
                    <TextBlock Grid.Column="1" Text="{Binding SelectedTrain.ConnectionStatus}"
                               Style="{StaticResource MonoCaptionTextBlockStyle}" TextWrapping="Wrap" />
                  </Grid>
                </StackPanel>
              </StackPanel>
            </Border>

            <!-- PORTS -->
            <Border Style="{StaticResource SectionCardStyle}">
              <StackPanel>
                <TextBlock Text="Ports &amp; Geräte" Style="{StaticResource SectionTitleTextBlockStyle}" Margin="0,0,0,18" />
                <StackPanel Spacing="18">

                  <Border Width="164" HorizontalAlignment="Left" Background="{ThemeResource SurfaceVariantBrush}" BorderBrush="{ThemeResource OutlineVariantBrush}"
                          BorderThickness="1" CornerRadius="{StaticResource RadiusLarge}" Padding="14" VerticalAlignment="Top">
                    <StackPanel Spacing="10">
                      <Border Height="28" CornerRadius="8" Background="{ThemeResource SurfaceBrush}" BorderBrush="{ThemeResource SurfaceVariantBrush}" BorderThickness="1">
                        <Border Width="12" Height="9" CornerRadius="2" Background="{Binding SelectedTrain.ColorHex, Converter={StaticResource HexToBrushConverter}}"
                                HorizontalAlignment="Right" Margin="0,0,8,0" />
                      </Border>
                      <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="*" />
                          <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="{ThemeResource PrimaryContainerBrush}" CornerRadius="10" Padding="0,9">
                          <StackPanel HorizontalAlignment="Center" Spacing="2">
                            <TextBlock Text="A" Style="{StaticResource MonoValueTextBlockStyle}" FontWeight="Bold" HorizontalAlignment="Center" />
                            <TextBlock Text="{Binding SelectedTrain.PortA}" Style="{StaticResource MonoCaptionTextBlockStyle}" FontSize="9.5" HorizontalAlignment="Center" />
                          </StackPanel>
                        </Border>
                        <Border Grid.Column="1" Background="{ThemeResource PrimaryContainerBrush}" CornerRadius="10" Padding="0,9">
                          <StackPanel HorizontalAlignment="Center" Spacing="2">
                            <TextBlock Text="B" Style="{StaticResource MonoValueTextBlockStyle}" FontWeight="Bold" HorizontalAlignment="Center" />
                            <TextBlock Text="{Binding SelectedTrain.PortB}" Style="{StaticResource MonoCaptionTextBlockStyle}" FontSize="9.5" HorizontalAlignment="Center" />
                          </StackPanel>
                        </Border>
                      </Grid>
                      <TextBlock Text="{Binding SelectedTrain.HubShort}" Style="{StaticResource MonoCaptionTextBlockStyle}" HorizontalAlignment="Center" />
                    </StackPanel>
                  </Border>

                  <StackPanel Spacing="16">
                    <StackPanel Spacing="7">
                      <TextBlock Text="Port A · Gerät" Style="{StaticResource LabelTextBlockStyle}" />
                      <ComboBox ItemsSource="{Binding DeviceOptions}" DisplayMemberPath="Label" SelectedValuePath="Value"
                                SelectedValue="{Binding SelectedTrain.PortA, Mode=TwoWay}" HorizontalAlignment="Stretch" />
                      <TextBlock Text="{Binding SelectedTrain.PortAToken}" Style="{StaticResource MonoCaptionTextBlockStyle}" />
                    </StackPanel>
                    <StackPanel Spacing="7">
                      <TextBlock Text="Port B · Gerät" Style="{StaticResource LabelTextBlockStyle}" />
                      <ComboBox ItemsSource="{Binding DeviceOptions}" DisplayMemberPath="Label" SelectedValuePath="Value"
                                SelectedValue="{Binding SelectedTrain.PortB, Mode=TwoWay}" HorizontalAlignment="Stretch" />
                      <TextBlock Text="{Binding SelectedTrain.PortBToken}" Style="{StaticResource MonoCaptionTextBlockStyle}" />
                    </StackPanel>
                  </StackPanel>
                </StackPanel>
              </StackPanel>
            </Border>

            <!-- ANTRIEB -->
            <Border Style="{StaticResource SectionCardStyle}">
              <StackPanel Spacing="18">
                <TextBlock Text="Antrieb" Style="{StaticResource SectionTitleTextBlockStyle}" />

                <StackPanel Spacing="12">
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*" />
                      <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Standard-Geschwindigkeit" Style="{StaticResource LabelTextBlockStyle}" VerticalAlignment="Center" />
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
                      <TextBlock Text="{Binding SelectedTrain.SpeedLabel}" FontFamily="{StaticResource MonoFontFamily}" FontSize="17" FontWeight="Bold" />
                      <TextBlock Text="{Binding SelectedTrain.SpeedDirectionLabel}" Style="{StaticResource MonoCaptionTextBlockStyle}" VerticalAlignment="Bottom" Margin="0,0,0,2" />
                    </StackPanel>
                  </Grid>
                  <Slider Minimum="-100" Maximum="100" StepFrequency="5" Value="{Binding SelectedTrain.Speed, Mode=TwoWay}" />
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*" />
                      <ColumnDefinition Width="*" />
                      <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="-100" Style="{StaticResource MonoCaptionTextBlockStyle}" HorizontalAlignment="Left" />
                    <TextBlock Grid.Column="1" Text="0" Style="{StaticResource MonoCaptionTextBlockStyle}" HorizontalAlignment="Center" />
                    <TextBlock Grid.Column="2" Text="+100" Style="{StaticResource MonoCaptionTextBlockStyle}" HorizontalAlignment="Right" />
                  </Grid>
                </StackPanel>

                <StackPanel Spacing="10">
                  <TextBlock Text="Geschwindigkeitsprofil f(x)" Style="{StaticResource LabelTextBlockStyle}" />
                  <Border Background="{ThemeResource SurfaceVariantBrush}" BorderBrush="{ThemeResource OutlineVariantBrush}" BorderThickness="1"
                          CornerRadius="{StaticResource RadiusLarge}" Padding="12,12,12,8">
                    <StackPanel Spacing="2">
                      <Viewbox Height="90" Stretch="Uniform">
                        <Canvas Width="300" Height="130">
                          <Path Data="{Binding SelectedTrain.Graph.FillPathData}" Fill="{ThemeResource PrimaryBrush}" Opacity=".12" />
                          <Path Data="{Binding SelectedTrain.Graph.LinePathData}" Stroke="{ThemeResource PrimaryBrush}" StrokeThickness="2.5" />
                        </Canvas>
                      </Viewbox>
                      <Grid Margin="34,0,0,0">
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="*" />
                          <ColumnDefinition Width="*" />
                          <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Beschl." Style="{StaticResource MonoCaptionTextBlockStyle}" FontSize="9.5" HorizontalAlignment="Left" />
                        <TextBlock Grid.Column="1" Text="konstant" Style="{StaticResource MonoCaptionTextBlockStyle}" FontSize="9.5" HorizontalAlignment="Center" />
                        <TextBlock Grid.Column="2" Text="Bremsen" Style="{StaticResource MonoCaptionTextBlockStyle}" FontSize="9.5" HorizontalAlignment="Right" />
                      </Grid>
                    </StackPanel>
                  </Border>

                  <StackPanel Spacing="16">
                    <StackPanel Spacing="7">
                      <TextBlock Text="Beschleunigung" Style="{StaticResource LabelTextBlockStyle}" />
                      <ComboBox ItemsSource="{Binding SpeedFunctionOptions}" DisplayMemberPath="Label" SelectedValuePath="Value"
                                SelectedValue="{Binding SelectedTrain.AccelFn, Mode=TwoWay}" HorizontalAlignment="Stretch" />
                      <Border Visibility="{Binding SelectedTrain.IsAccelCustom, Converter={StaticResource BoolToVisibilityConverter}}"
                              BorderBrush="{Binding SelectedTrain.IsAccelFormulaValid, Converter={StaticResource ValidityToBrushConverter}}"
                              BorderThickness="1" CornerRadius="{StaticResource RadiusMedium}" Padding="12,10">
                        <StackPanel Orientation="Horizontal" Spacing="7">
                          <TextBlock Text="f(x)=" FontFamily="{StaticResource MonoFontFamily}" FontSize="12" Foreground="{ThemeResource MutedTextBrush}" />
                          <TextBox Text="{Binding SelectedTrain.AccelExpression, Mode=TwoWay}" FontFamily="{StaticResource MonoFontFamily}"
                                   FontSize="12" Background="Transparent" BorderThickness="0" Padding="0" />
                        </StackPanel>
                      </Border>
                      <TextBlock Text="{Binding SelectedTrain.AccelFormulaDisplay}"
                                 Foreground="{Binding SelectedTrain.IsAccelFormulaValid, Converter={StaticResource ValidityToBrushConverter}}"
                                 FontFamily="{StaticResource MonoFontFamily}" FontSize="10.5" />
                    </StackPanel>
                    <StackPanel Spacing="7">
                      <TextBlock Text="Bremsen" Style="{StaticResource LabelTextBlockStyle}" />
                      <ComboBox ItemsSource="{Binding SpeedFunctionOptions}" DisplayMemberPath="Label" SelectedValuePath="Value"
                                SelectedValue="{Binding SelectedTrain.BrakeFn, Mode=TwoWay}" HorizontalAlignment="Stretch" />
                      <Border Visibility="{Binding SelectedTrain.IsBrakeCustom, Converter={StaticResource BoolToVisibilityConverter}}"
                              BorderBrush="{Binding SelectedTrain.IsBrakeFormulaValid, Converter={StaticResource ValidityToBrushConverter}}"
                              BorderThickness="1" CornerRadius="{StaticResource RadiusMedium}" Padding="12,10">
                        <StackPanel Orientation="Horizontal" Spacing="7">
                          <TextBlock Text="f(x)=" FontFamily="{StaticResource MonoFontFamily}" FontSize="12" Foreground="{ThemeResource MutedTextBrush}" />
                          <TextBox Text="{Binding SelectedTrain.BrakeExpression, Mode=TwoWay}" FontFamily="{StaticResource MonoFontFamily}"
                                   FontSize="12" Background="Transparent" BorderThickness="0" Padding="0" />
                        </StackPanel>
                      </Border>
                      <TextBlock Text="{Binding SelectedTrain.BrakeFormulaDisplay}"
                                 Foreground="{Binding SelectedTrain.IsBrakeFormulaValid, Converter={StaticResource ValidityToBrushConverter}}"
                                 FontFamily="{StaticResource MonoFontFamily}" FontSize="10.5" />
                    </StackPanel>
                  </StackPanel>
                </StackPanel>
              </StackPanel>
            </Border>

            <!-- FARBE & LED -->
            <Border Style="{StaticResource SectionCardStyle}">
              <StackPanel>
                <TextBlock Text="Farbe &amp; Hub-LED" Style="{StaticResource SectionTitleTextBlockStyle}" Margin="0,0,0,16" />
                <ItemsControl ItemsSource="{Binding ColorSwatches}">
                  <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                      <VariableSizedWrapGrid Orientation="Horizontal" ItemWidth="40" ItemHeight="40" MaximumRowsOrColumns="20" />
                    </ItemsPanelTemplate>
                  </ItemsControl.ItemsPanel>
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Button Width="34" Height="34" Padding="0" BorderThickness="0" CornerRadius="11" Margin="0,0,6,6"
                              Background="{Binding Hex, Converter={StaticResource HexToBrushConverter}}"
                              Command="{Binding ElementName=RootPage, Path=DataContext.SetColorCommand}"
                              CommandParameter="{Binding Value}"
                              ToolTipService.ToolTip="{Binding Name}">
                        <Border BorderBrush="{ThemeResource PrimaryBrush}" CornerRadius="11" Margin="-4"
                                BorderThickness="{Binding IsSelected, Converter={StaticResource BoolToThicknessConverter}, ConverterParameter=2.5}" />
                      </Button>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
                <TextBlock Text="{Binding SelectedTrain.ColorToken}" Style="{StaticResource MonoCaptionTextBlockStyle}" Margin="0,13,0,0" />
              </StackPanel>
            </Border>

          </StackPanel>
        </ScrollViewer>

        <StackPanel Visibility="{Binding SelectedTrain, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=Invert}"
                    HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="16">
          <FontIcon Glyph="&#xE7C0;" FontSize="54" Foreground="{ThemeResource OutlineVariantBrush}" HorizontalAlignment="Center" />
          <TextBlock Text="Wähle einen Train aus oder lege einen neuen an." FontSize="14" Foreground="{ThemeResource OnSurfaceVariantBrush}" HorizontalAlignment="Center" />
          <Button Content="+ Neuer Train" Style="{StaticResource FabButtonStyle}" Command="{Binding AddTrainCommand}" HorizontalAlignment="Center" Padding="20,0" />
        </StackPanel>
      </Grid>
    </Grid>

    <!-- ADD-HUB POPUP (styled, modal) - shown while a discovered hub awaits confirmation -->
    <Grid Grid.Row="0" Grid.RowSpan="2" Background="#B3000000"
          Visibility="{Binding PendingHub, Converter={StaticResource NullToVisibilityConverter}}">
      <Border MaxWidth="360" Margin="24" VerticalAlignment="Center" HorizontalAlignment="Center"
              Background="{ThemeResource SurfaceBrush}" BorderBrush="{ThemeResource SurfaceVariantBrush}" BorderThickness="1"
              CornerRadius="{StaticResource RadiusLarge}" Padding="24">
        <StackPanel Spacing="16">
          <Border Width="48" Height="48" CornerRadius="14" Background="{ThemeResource PrimaryContainerBrush}" HorizontalAlignment="Left">
            <FontIcon Glyph="&#xE702;" FontSize="22" Foreground="{ThemeResource OnPrimaryContainerBrush}" />
          </Border>

          <StackPanel Spacing="4">
            <TextBlock Text="Hub gefunden" FontSize="18" FontWeight="Bold" />
            <TextBlock Text="Als Train hinzufügen und verbinden?" FontSize="13"
                       Foreground="{ThemeResource OnSurfaceVariantBrush}" TextWrapping="Wrap" />
          </StackPanel>

          <Border Background="{ThemeResource SurfaceVariantBrush}" CornerRadius="{StaticResource RadiusMedium}" Padding="14,10">
            <StackPanel Spacing="2">
              <TextBlock Text="{Binding PendingHub.Name}" FontWeight="SemiBold" FontSize="14" TextTrimming="CharacterEllipsis" />
              <TextBlock Text="{Binding PendingHub.MacAddress}" Style="{StaticResource MonoCaptionTextBlockStyle}" />
            </StackPanel>
          </Border>

          <Grid ColumnSpacing="10" Margin="0,4,0,0">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Content="Abbrechen" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                    Command="{Binding CancelAddHubCommand}" />
            <Button Grid.Column="1" Content="Verbinden" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                    Style="{StaticResource FabButtonStyle}" Command="{Binding ConfirmAddHubCommand}" />
          </Grid>
        </StackPanel>
      </Border>
    </Grid>
  </Grid>
</Page>
