<UserControl x:Class="Trackify.Presentation.Components.TrainListPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Trackify.Presentation.ViewModels"
             xmlns:models="using:Trackify.Models.Trains"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:MainViewModel}">

  <!-- Train list rail: search, hub discovery, filter, the list, and "new train". Binds to MainViewModel. -->
  <Grid Background="{ThemeResource SurfaceBrush}" BorderBrush="{ThemeResource SurfaceVariantBrush}" BorderThickness="0,0,1,0">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <StackPanel Grid.Row="0" Padding="16,16,16,14" Spacing="12">
      <Grid>
        <TextBox Text="{Binding Search, Mode=TwoWay}"
                 PlaceholderText="Train suchen…"
                 Padding="34,11,14,11"
                 BorderThickness="0"
                 CornerRadius="{StaticResource RadiusFull}"
                 Background="{ThemeResource SurfaceVariantBrush}"
                 FontSize="13.5" />
        <FontIcon Glyph="&#xE721;" FontSize="14" Margin="13,0,0,0" HorizontalAlignment="Left" Foreground="{ThemeResource OnSurfaceVariantBrush}" IsHitTestVisible="False" />
      </Grid>

      <Button HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
              Command="{Binding DiscoverCommand}" IsEnabled="{Binding IsDiscovering, Converter={StaticResource InverseBoolConverter}}">
        <StackPanel Orientation="Horizontal" Spacing="8">
          <FontIcon Glyph="&#xE702;" FontSize="15" />
          <TextBlock Text="Hub suchen" />
        </StackPanel>
      </Button>

      <Border Background="{ThemeResource SurfaceVariantBrush}" CornerRadius="{StaticResource RadiusLarge}" Padding="12,10"
              Visibility="{Binding DiscoverStatus, Converter={StaticResource NullToVisibilityConverter}}">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>
          <ProgressRing Grid.Column="0" Width="16" Height="16" Margin="0,0,8,0" VerticalAlignment="Center"
                        IsActive="{Binding IsDiscovering}"
                        Visibility="{Binding IsDiscovering, Converter={StaticResource BoolToVisibilityConverter}}" />
          <TextBlock Grid.Column="1" Text="{Binding DiscoverStatus}" TextWrapping="Wrap" VerticalAlignment="Center"
                     FontSize="12" Foreground="{ThemeResource OnSurfaceVariantBrush}" />
          <Button Grid.Column="2" Content="Stopp" Padding="12,4" Command="{Binding StopDiscoverCommand}"
                  Visibility="{Binding IsDiscovering, Converter={StaticResource BoolToVisibilityConverter}}" />
          <Button Grid.Column="2" Style="{StaticResource IconButtonStyle}" Command="{Binding ClearDiscoverCommand}"
                  ToolTipService.ToolTip="Ausblenden"
                  Visibility="{Binding IsDiscovering, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}">
            <FontIcon Glyph="&#xE711;" FontSize="12" />
          </Button>
        </Grid>
      </Border>

      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Button Grid.Column="0" Content="Alle" Style="{StaticResource SegmentPillButtonStyle}"
                CornerRadius="19,0,0,19"
                Background="{Binding Filter, Converter={StaticResource SegmentBackgroundConverter}, ConverterParameter=All}"
                Foreground="{Binding Filter, Converter={StaticResource SegmentForegroundConverter}, ConverterParameter=All}"
                Command="{Binding SetFilterCommand}" CommandParameter="All" />
        <Button Grid.Column="1" Content="Aktiv" Style="{StaticResource SegmentPillButtonStyle}"
                CornerRadius="0" Margin="-1,0,0,0"
                Background="{Binding Filter, Converter={StaticResource SegmentBackgroundConverter}, ConverterParameter=Active}"
                Foreground="{Binding Filter, Converter={StaticResource SegmentForegroundConverter}, ConverterParameter=Active}"
                Command="{Binding SetFilterCommand}" CommandParameter="Active" />
        <Button Grid.Column="2" Content="Inaktiv" Style="{StaticResource SegmentPillButtonStyle}"
                CornerRadius="0,19,19,0" Margin="-1,0,0,0"
                Background="{Binding Filter, Converter={StaticResource SegmentBackgroundConverter}, ConverterParameter=Inactive}"
                Foreground="{Binding Filter, Converter={StaticResource SegmentForegroundConverter}, ConverterParameter=Inactive}"
                Command="{Binding SetFilterCommand}" CommandParameter="Inactive" />
      </Grid>
    </StackPanel>

    <ListView Grid.Row="1"
              ItemsSource="{Binding FilteredTrains}"
              SelectedItem="{Binding SelectedTrain, Mode=TwoWay}"
              SelectionMode="Single"
              Padding="10,2,10,10">
      <ListView.ItemContainerStyle>
        <Style TargetType="ListViewItem">
          <Setter Property="Padding" Value="0" />
          <Setter Property="Margin" Value="0,0,0,4" />
          <Setter Property="CornerRadius" Value="{StaticResource RadiusLarge}" />
          <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        </Style>
      </ListView.ItemContainerStyle>
      <ListView.ItemTemplate>
        <DataTemplate>
          <Grid Padding="10" ColumnSpacing="12" d:DataContext="{d:DesignInstance Type=models:Train}">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Width="42" Height="42" CornerRadius="12"
                    Background="{Binding ColorHex, Converter={StaticResource HexToBrushConverter}}" Opacity=".88">
              <Grid Width="23" Height="23">
                <Path Data="M5 4h11a3 3 0 0 1 3 3v8H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2Z" Fill="White" />
                <Ellipse Width="4" Height="4" Fill="#1D1B20" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="6,15,0,0" />
                <Ellipse Width="4" Height="4" Fill="#1D1B20" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="13,15,0,0" />
              </Grid>
            </Border>

            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
              <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
              <TextBlock Text="{Binding PortSummary}" Style="{StaticResource MonoCaptionTextBlockStyle}" TextTrimming="CharacterEllipsis" />
            </StackPanel>

            <Ellipse Grid.Column="2" Width="9" Height="9" VerticalAlignment="Center"
                      Fill="{Binding IsActive, Converter={StaticResource BoolToStatusBrushConverter}}" />
          </Grid>
        </DataTemplate>
      </ListView.ItemTemplate>
    </ListView>

    <Button Grid.Row="2" Margin="16,14,16,14" Style="{StaticResource FabButtonStyle}" Command="{Binding AddTrainCommand}">
      <StackPanel Orientation="Horizontal" Spacing="8">
        <FontIcon Glyph="&#xE710;" FontSize="16" />
        <TextBlock Text="Neuer Train" />
      </StackPanel>
    </Button>
  </Grid>
</UserControl>
