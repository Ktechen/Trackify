<UserControl x:Class="Trackify.Presentation.Widgets.SpeedProfileWidget"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- Reusable f(x) speed-profile chart (train drive + track segment). Bind the Graph property. -->
  <Border Background="{ThemeResource SurfaceVariantBrush}" BorderBrush="{ThemeResource OutlineVariantBrush}" BorderThickness="1"
          CornerRadius="{StaticResource RadiusLarge}" Padding="12,12,12,8">
    <StackPanel Spacing="2">
      <Viewbox Height="90" Stretch="Uniform">
        <Canvas Width="300" Height="130">
          <Path Data="{Binding Graph.FillPathData, ElementName=Root}" Fill="{ThemeResource PrimaryBrush}" Opacity=".12" />
          <Path Data="{Binding Graph.LinePathData, ElementName=Root}" Stroke="{ThemeResource PrimaryBrush}" StrokeThickness="2.5" />
        </Canvas>
      </Viewbox>
      <Grid Margin="34,0,0,0">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <TextBlock Grid.Column="0" Text="Beschl." Style="{StaticResource MonoCaptionTextBlockStyle}" FontSize="9.5" HorizontalAlignment="Left" />
        <TextBlock Grid.Column="1" Text="konstant" Style="{StaticResource MonoCaptionTextBlockStyle}" FontSize="9.5" HorizontalAlignment="Center" />
        <TextBlock Grid.Column="2" Text="Bremsen" Style="{StaticResource MonoCaptionTextBlockStyle}" FontSize="9.5" HorizontalAlignment="Right" />
      </Grid>
    </StackPanel>
  </Border>
</UserControl>
