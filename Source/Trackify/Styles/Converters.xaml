<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="using:Trackify.Presentation.Converters">

  <!-- Registered once here (merged in App.xaml) so every screen, component and widget can use
       them via {StaticResource ...} without re-declaring them per page. -->
  <conv:HexToBrushConverter x:Key="HexToBrushConverter" />
  <conv:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
  <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
  <conv:InverseBoolConverter x:Key="InverseBoolConverter" />
  <conv:BoolToStatusBrushConverter x:Key="BoolToStatusBrushConverter" />
  <conv:SegmentBackgroundConverter x:Key="SegmentBackgroundConverter" />
  <conv:SegmentForegroundConverter x:Key="SegmentForegroundConverter" />
  <conv:BoolToThicknessConverter x:Key="BoolToThicknessConverter" />
  <conv:ValidityToBrushConverter x:Key="ValidityToBrushConverter" />

</ResourceDictionary>
